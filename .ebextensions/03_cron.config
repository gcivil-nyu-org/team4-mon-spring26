files:
  "/etc/cron.d/tenantguard_data_refresh":
    mode: "000644"
    owner: root
    group: root
    content: |
      # Refresh data daily at 2 AM UTC
      0 2 * * * root source /var/app/venv/*/bin/activate && cd /var/app/current && python manage.py ingest_all --limit 5000 >> /var/log/tenantguard_cron.log 2>&1
      # Recompute risk scores after data refresh
      30 2 * * * root source /var/app/venv/*/bin/activate && cd /var/app/current && python manage.py compute_risk_scores >> /var/log/tenantguard_cron.log 2>&1

commands:
  remove_old_cron:
    command: "rm -f /etc/cron.d/*.bak"
