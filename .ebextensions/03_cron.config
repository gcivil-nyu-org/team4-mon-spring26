files:
  "/etc/cron.d/scheduled_ingestion":
    mode: "000644"
    owner: root
    group: root
    content: |
      0 */1 * * * root /var/app/venv/*/bin/python /var/app/current/manage.py run_scheduled_ingestion >> /var/log/scheduled_ingestion.log 2>&1

commands:
  remove_old_cron:
    command: "rm -f /etc/cron.d/scheduled_ingestion.bak"
